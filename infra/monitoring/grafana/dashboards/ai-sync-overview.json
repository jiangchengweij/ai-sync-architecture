{
  "dashboard": {
    "title": "AI Project Sync Overview",
    "uid": "ai-sync-overview",
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
      {
        "title": "Sync Success Rate",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
        "targets": [{ "expr": "sync_success_rate", "legendFormat": "Success Rate" }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.7 },
                { "color": "green", "value": 0.9 }
              ]
            },
            "unit": "percentunit", "min": 0, "max": 1
          }
        }
      },
      {
        "title": "Pending Reviews",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
        "targets": [{ "expr": "review_pending_count", "legendFormat": "Pending" }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 20 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        }
      },
      {
        "title": "Queue Depth",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
        "targets": [{ "expr": "sum(queue_depth)", "legendFormat": "Total Jobs" }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 100 },
                { "color": "red", "value": 500 }
              ]
            }
          }
        }
      },
      {
        "title": "WebSocket Connections",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
        "targets": [{ "expr": "websocket_active_connections", "legendFormat": "Connections" }]
      },
      {
        "title": "Sync Tasks Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "targets": [
          { "expr": "rate(sync_tasks_total{status=\"completed\"}[5m])", "legendFormat": "Completed" },
          { "expr": "rate(sync_tasks_total{status=\"failed\"}[5m])", "legendFormat": "Failed" }
        ]
      },
      {
        "title": "Sync Duration (P50 / P99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "targets": [
          { "expr": "histogram_quantile(0.5, rate(sync_duration_seconds_bucket[5m]))", "legendFormat": "P50" },
          { "expr": "histogram_quantile(0.99, rate(sync_duration_seconds_bucket[5m]))", "legendFormat": "P99" }
        ],
        "fieldConfig": { "defaults": { "unit": "s" } }
      },
      {
        "title": "AI API Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
        "targets": [
          { "expr": "histogram_quantile(0.5, rate(ai_api_latency_seconds_bucket[5m]))", "legendFormat": "P50" },
          { "expr": "histogram_quantile(0.99, rate(ai_api_latency_seconds_bucket[5m]))", "legendFormat": "P99" }
        ],
        "fieldConfig": { "defaults": { "unit": "s" } }
      },
      {
        "title": "AI API Errors",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
        "targets": [
          { "expr": "rate(ai_api_errors_total[5m])", "legendFormat": "{{ error_type }}" }
        ]
      },
      {
        "title": "HTTP Request Duration",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
        "targets": [
          { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "{{ route }} P99" }
        ],
        "fieldConfig": { "defaults": { "unit": "s" } }
      },
      {
        "title": "Queue Depth by Queue",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
        "targets": [
          { "expr": "queue_depth", "legendFormat": "{{ queue_name }}" }
        ]
      }
    ]
  }
}
